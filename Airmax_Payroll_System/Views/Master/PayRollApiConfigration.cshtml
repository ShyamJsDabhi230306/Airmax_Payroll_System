@* Path: Airmax_Payroll_System/Views/Master/PayRollApiConfigration.cshtml *@
@{
    ViewBag.Title = "API & Attendance Configuration";
}

<div class="row">
    <!-- Page Header -->
    <!-- PAGE HEADER / TOP ACTION BAR -->
    <div class="col-12 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-header d-flex justify-content-between align-items-center bg-white py-3">
                <h4 class="card-title mb-0 fw-bold text-primary">
                    <i class="fas fa-cog me-2"></i>API & Attendance Configuration
                </h4>

                <div class="d-flex align-items-center gap-3">
                    <!-- Company Selection (Mapped to IDCompany) -->
                    <div class="d-flex align-items-center gap-2">
                        <label class="small fw-bold text-muted text-uppercase mb-0" style="font-size:11px;">Company</label>
                        <select id="IDCompany" name="IDCompany" class="form-control selectpicker shadow-none" data-width="200px" data-style="btn-light border">
                            <option value="1">Aira</option>
                            <option value="2">Airmax</option>
                            <!-- Other companies will be loaded dynamically via JS -->
                        </select>
                    </div>

                    <div class="vr mx-2"></div> <!-- Vertical Separator -->
                    <!-- Save All Button -->
                    <button class="btn btn-primary px-4 fw-bold shadow-sm" onclick="saveAll()">
                        <i class="fas fa-save me-1"></i> Save All Settings
                    </button>
                </div>
            </div>
        </div>
    </div>


    <!-- Navigation Tabs -->
    <div class="col-12 mb-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-2">
                <ul class="nav nav-pills nav-fill" id="configTabs" role="tablist">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#tab-conn"><i class="fas fa-plug me-2"></i>Connection</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-pull"><i class="fas fa-cloud-download-alt me-2"></i>Pull API</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-dev"><i class="fas fa-microchip me-2"></i>Devices</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-sync"><i class="fas fa-sync-alt me-2"></i>Sync Settings</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-endpoints"><i class="fas fa-sync-alt me-2"></i>EndPointTesting</button></li>
                    <li class="nav-item"><button class="nav-link text-success" data-bs-toggle="pill" data-bs-target="#tab-test"><i class="fas fa-vial me-2"></i>API Tester</button></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="tab-content" id="configTabsContent">

            
            <!-- 1. CONNECTION TAB -->
            <div class="tab-pane fade show active" id="tab-conn" role="tabpanel">

                <!-- Hidden Primary Keys (SQL Mapped) -->
                <input type="hidden" id="IDPayrollApiConfigration" name="IDPayrollApiConfigration" value="0" />
                <input type="hidden" id="IDCompany" name="IDCompany" value="1" />

                <!-- Status Summary Cards -->
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm border-start border-4 border-success h-100">
                            <div class="card-body p-3">
                                <div class="small fw-bold text-muted text-uppercase mb-1" style="font-size:10px;">Connection</div>
                                <h4 class="text-success fw-bold mb-0">Online</h4>
                                <small class="text-muted" style="font-size:11px;">Last pinged 12s ago</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm border-start border-4 border-primary h-100">
                            <div class="card-body p-3">
                                <div class="small fw-bold text-muted text-uppercase mb-1" style="font-size:10px;">Active Devices</div>
                                <h4 class="fw-bold mb-0">3 / 3</h4>
                                <small class="text-muted" style="font-size:11px;">All reporting</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm border-start border-4 border-info h-100">
                            <div class="card-body p-3">
                                <div class="small fw-bold text-muted text-uppercase mb-1" style="font-size:10px;">Last Pull</div>
                                <h4 class="fw-bold mb-0">2m 14s</h4>
                                <small class="text-muted" style="font-size:11px;">142 logs fetched</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm border-start border-4 border-warning h-100">
                            <div class="card-body p-3">
                                <div class="small fw-bold text-muted text-uppercase mb-1" style="font-size:10px;">Pending Cmds</div>
                                <h4 class="text-warning fw-bold mb-0">2</h4>
                                <small class="text-muted" style="font-size:11px;">In queue</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SmartOffice API Connection Card -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-key text-warning me-2"></i>SmartOffice API Connection</h6>
                        <span class="badge bg-success-light text-success fw-bold" style="font-size:10px;">● Connected</span>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Base URL</label>
                                <input type="text" id="BaseUrl" name="BaseUrl" class="form-control bg-light font-monospace" placeholder="https://sohcm.com/SmartApp_ess">
                                <div class="form-text small" style="font-size:11px;">SmartOffice cloud endpoint (no trailing slash)</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Account Name</label>
                                <input type="text" id="AccountName" name="AccountName" class="form-control bg-light" placeholder="ACE">
                                <div class="form-text small" style="font-size:11px;">Tenant identifier on SmartOffice cloud</div>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">API Key (Authentication Token)</label>
                                <div class="input-group input-group-sm">
                                    <input type="password" id="ApiKey" name="ApiKey" class="form-control bg-light font-monospace" placeholder="••••••••••••">
                                    <button class="btn btn-secondary px-3" type="button" onclick="togglePass('ApiKey')">Show</button>
                                </div>
                                <div class="form-text small" style="font-size:11px;">Provided by SmartOffice — used in every request</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Pull API Endpoint</label>
                                <div class="input-group input-group-sm">
                                    <input type="text" id="PullApiEndPoint" name="PullApiEndPoint" class="form-control bg-light font-monospace" value="/api/SwipeDetails/GetDeviceLogs">
                                    <button class="btn btn-primary px-3" type="button" onclick="copyVal('PullApiEndPoint')">Copy</button>
                                </div>
                                <div class="form-text small" style="font-size:11px;">Appended to base URL when polling</div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-uppercase text-muted">Request Timeout (Sec)</label>
                                <input type="number" id="RequestTimeout" name="RequestTimeout" class="form-control bg-light" value="30">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-uppercase text-muted">Retry Attempt of Failure</label>
                                <input type="number" id="RetryAttemptOfFailer" name="RetryAttemptOfFailer" class="form-control bg-light" value="3">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-uppercase text-muted">Retry Backoff (Sec)</label>
                                <input type="number" id="RetryBackOff" name="RetryBackOff" class="form-control bg-light" value="5">
                                <div class="form-text small" style="font-size:11px;">Wait between retries</div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white py-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary btn-sm fw-bold px-3" onclick="testConnection()">
                                <i class="fas fa-bolt me-2"></i>Test Connection
                            </button>
                            <button class="btn btn-outline-secondary btn-sm fw-bold px-3" onclick="copyFullUrl()">
                                <i class="fas fa-copy me-2"></i>Copy Full Pull URL
                            </button>
                        </div>
                        <div class="small text-muted fw-bold" style="font-size:11px;">
                            Last test: <span class="text-success">200 OK</span> · 248ms
                        </div>
                    </div>
                </div>

                <!-- Authentication & Security Card (Checkboxes mapped to SQL BIT columns) -->
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-lock text-danger me-2"></i>Authentication & Security</h6>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold mb-0 small">Use HTTPS only</div>
                                        <div class="text-muted extra-small" style="font-size:11px;">Reject http:// requests — recommended for production</div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="UseHTTPSOnly" name="UseHTTPSOnly" checked>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold mb-0 small">Mask API key in logs</div>
                                        <div class="text-muted extra-small" style="font-size:11px;">Never write API key to file logs (only first 4 + last 2 chars)</div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="maskApiInLog" name="maskApiInLog" checked>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item py-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold mb-0 small">IP whitelist enforcement</div>
                                        <div class="text-muted extra-small" style="font-size:11px;">Only allow requests from registered IPs</div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="IPWhiteListEnforcement" name="IPWhiteListEnforcement">
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item py-3 border-0">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold mb-0 small">Auto-rotate API key every 90 days</div>
                                        <div class="text-muted extra-small" style="font-size:11px;">Notify admin via email before expiry</div>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="AutoRotateApiKeyOnEvery90Days" name="AutoRotateApiKeyOnEvery90Days">
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>


            <!-- 2. PULL API TAB -->
            <div class="tab-pane fade" id="tab-pull" role="tabpanel">

                <!-- Polling Schedule Card (Mapped to SQL) -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-clock text-primary me-2"></i>Polling Schedule & Frequency</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-uppercase text-muted">Pull Frequency</label>
                                <select id="PullFrequency" name="PullFrequency" class="form-control selectpicker shadow-none" data-style="btn-light border">
                                    <option value="5">Every 5 Minutes</option>
                                    <option value="15" selected>Every 15 Minutes</option>
                                    <option value="30">Every 30 Minutes</option>
                                    <option value="60">Every 1 Hour</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-uppercase text-muted">Date Range Window</label>
                                <select id="DateRangeWindow" name="DateRangeWindow" class="form-control selectpicker shadow-none" data-style="btn-light border">
                                    <option value="1">Last 1 Day</option>
                                    <option value="2" selected>Last 2 Days</option>
                                    <option value="7">Last 7 Days</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-uppercase text-muted">Active Hours</label>
                                <select id="ActiveHours" name="ActiveHours" class="form-control selectpicker shadow-none" data-style="btn-light border">
                                    <option value="24" selected>24/7 (Always Active)</option>
                                    <option value="08-18">08:00 - 18:00</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Data Selection Toggles (Mapped to SQL BIT Columns) -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-check-double text-success me-2"></i>Data Selection Toggles</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-4">
                            <div class="col-md-3 border-end">
                                <div class="form-check form-switch mb-1">
                                    <input class="form-check-input" type="checkbox" id="UserIDPull" name="UserIDPull" checked>
                                    <label class="form-check-label fw-bold small">User ID Pull</label>
                                </div>
                            </div>
                            <div class="col-md-3 border-end">
                                <div class="form-check form-switch mb-1">
                                    <input class="form-check-input" type="checkbox" id="LogDate" name="LogDate" checked>
                                    <label class="form-check-label fw-bold small">Log Date/Time</label>
                                </div>
                            </div>
                            <div class="col-md-3 border-end">
                                <div class="form-check form-switch mb-1">
                                    <input class="form-check-input" type="checkbox" id="SerialNumberPull" name="SerialNumberPull" checked>
                                    <label class="form-check-label fw-bold small">Serial Number</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check form-switch mb-1">
                                    <input class="form-check-input" type="checkbox" id="DeviceNamePull" name="DeviceNamePull">
                                    <label class="form-check-label fw-bold small">Device Name</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Field Mapping Table (Mapped to SQL nvarchar(max) Columns) -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-table text-info me-2"></i>Field Mapping → Payroll System</h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light small fw-bold text-uppercase">
                                    <tr>
                                        <th class="ps-4">SmartOffice Field</th>
                                        <th>Payroll System Column</th>
                                        <th>Transformation</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Row 1: UserID -->
                                    <tr>
                                        <td class="ps-4 fw-bold small">UserId</td>
                                        <td><input type="text" id="UseridPayroll" name="UseridPayroll" class="form-control form-control-sm" value="employees.staff_code"></td>
                                        <td><input type="text" id="UseridTransform" name="UseridTransform" class="form-control form-control-sm" placeholder="None"></td>
                                    </tr>
                                    <!-- Row 2: LogDate -->
                                    <tr>
                                        <td class="ps-4 fw-bold small">LogDate</td>
                                        <td><input type="text" id="LogDatePayroll" name="LogDatePayroll" class="form-control form-control-sm" value="punches.punch_time"></td>
                                        <td><input type="text" id="LogdateTransform" name="LogdateTransform" class="form-control form-control-sm" placeholder="None"></td>
                                    </tr>
                                    <!-- Row 3: SerialNumber -->
                                    <tr>
                                        <td class="ps-4 fw-bold small">SerialNumber</td>
                                        <td><input type="text" id="SerialNumberPayroll" name="SerialNumberPayroll" class="form-control form-control-sm" value="punches.machine_serial"></td>
                                        <td><input type="text" id="SerialNumberTransform" name="SerialNumberTransform" class="form-control form-control-sm" placeholder="None"></td>
                                    </tr>
                                    <!-- Row 4: DeviceSName (The one you requested) -->
                                    <tr>
                                        <td class="ps-4 fw-bold small">DeviceName</td>
                                        <td><input type="text" id="DeviceSNamesPayroll" name="DeviceSNamesPayroll" class="form-control form-control-sm" placeholder="punches.device_name"></td>
                                        <td><input type="text" id="deviceSNamesTransform" name="deviceSNamesTransform" class="form-control form-control-sm" placeholder="None"></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Duplicate Handling Card (Mapped to SQL) -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-shield-alt text-warning me-2"></i>Duplicate Handling & Validation</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">On Duplicate Punch</label>
                                <select id="OnDuplicatePunch" name="OnDuplicatePunch" class="form-control selectpicker shadow-none" data-style="btn-light border">
                                    <option value="Ignore">Ignore</option>
                                    <option value="Overwrite">Overwrite</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Unknown Employee Code</label>
                                <select id="UnknownEmployeeCode" name="UnknownEmployeeCode" class="form-control selectpicker shadow-none" data-style="btn-light border">
                                    <option value="LogError">Log Error</option>
                                    <option value="Create">Create</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-3 border-top pt-3">
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="RejectFuturePunch" name="RejectFuturePunch" checked>
                                    <label class="form-check-label fw-bold small">Reject Future Punches</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="RejectOldPunch" name="RejectOldPunch">
                                    <label class="form-check-label fw-bold small">Reject Old Punches</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="EmailOnFailure" name="EmailOnFailure">
                                    <label class="form-check-label fw-bold small">Email on Failure</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>



            <!-- 3. DEVICES TAB -->
            <div class="tab-pane fade" id="tab-dev">

                <!-- Biometric Devices Table Card -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-0 fw-bold"><i class="fas fa-microchip text-primary me-2"></i>Biometric Device Management</h6>
                            <small class="text-muted">Total Registered: <span id="dev-count-text" class="fw-bold text-primary">0</span></small>
                        </div>
                        <div class="d-flex gap-2">
                            <span class="badge bg-success-light text-success border border-success-subtle px-3 py-2 rounded-pill fw-bold" style="font-size:10px;">● 3 Online</span>
                            <button class="btn btn-primary btn-sm rounded-pill px-3 fw-bold shadow-sm" onclick="addDeviceRow()">
                                <i class="fas fa-plus me-1"></i> Add Device
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="alert alert-primary border-0 rounded-0 small mb-0 p-2 text-center" style="background:#EFF6FF; color:#1E40AF;">
                            <i class="fas fa-info-circle me-2"></i>Devices are synced with SmartOffice via <code>/AddBiometric</code>. Changes save to local DB and Cloud.
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered mb-0 align-middle">
                                <thead class="table-light small fw-bold text-uppercase text-center">
                                    <tr>
                                        <th width="50">#</th>
                                        <th>Device Name</th>
                                        <th>Serial Number</th>
                                        <th>Model / Type</th>
                                        <th>Location</th>
                                        <th width="100">Status</th>
                                        <th width="50">#</th>
                                    </tr>
                                </thead>
                                <tbody id="tblDeviceBody" class="text-center">
                                    <!-- Dynamic rows will be injected here via JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Device-Wide Capabilities Card -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-cog text-secondary me-2"></i>Device-Wide Global Capabilities</h6>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label small fw-bold text-uppercase text-muted">Default Verify Mode</label>
                                <select id="DefaultVerifyMode" class="form-control selectpicker shadow-none" data-style="btn-light border">
                                    <option value="Face">Face Only</option>
                                    <option value="Finger">Fingerprint Only</option>
                                    <option value="Card">Card Only</option>
                                    <option value="Face+Card" selected>Face + Card (Dual)</option>
                                    <option value="Any">Any Mode</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-bold text-uppercase text-muted">Upload Face Templates</label>
                                <select id="UploadFaceTemplates" class="form-control selectpicker shadow-none" data-style="btn-light border">
                                    <option value="True">Enabled</option>
                                    <option value="False">Disabled</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-bold text-uppercase text-muted">Upload Fingerprints</label>
                                <select id="UploadFingerprints" class="form-control selectpicker shadow-none" data-style="btn-light border">
                                    <option value="True">Enabled</option>
                                    <option value="False">Disabled</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-bold text-uppercase text-muted">Upload Cards</label>
                                <select id="UploadCards" class="form-control selectpicker shadow-none" data-style="btn-light border">
                                    <option value="True">Enabled</option>
                                    <option value="False">Disabled</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Device Maintenance Commands Card -->
