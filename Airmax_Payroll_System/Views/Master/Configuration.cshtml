@{
    ViewBag.Title = "Master Configuration";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-0 text-primary fw-bold">Master Configuration</h5>
            <small class="text-muted">Manage loan limits per company</small>
        </div>
        <button type="button" class="btn btn-primary btn-sm px-4 fw-bold shadow-sm" onclick="openModal()">
            <i class="fas fa-plus-circle me-1"></i> ADD NEW
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table id="configList" class="table table-hover align-middle border">
                <thead class="bg-light">
                    <tr class="small text-muted text-uppercase">
                        <th>Company Name</th>
                        <th class="text-end pe-4">Loan Limit</th>
                        <th class="text-center" style="width:50px">Action</th>
                    </tr>
                </thead>
                <tbody id="tblBody">
                    <tr><td colspan="3" class="text-center py-5 text-muted">Loading...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ENTRY MODAL -->
<div class="modal fade" id="addModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg ">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalTitle">Add Configuration</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="IDConfiguration" value="0" />

                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">Select Company</label>
                    <select id="IDCompany" class="form-control"></select>
                </div>

                <div class="mb-0">
                    <label class="form-label fw-bold small text-uppercase">Loan Limit (₹)</label>
                    <!-- 🔥 Changed to type="text" to remove browser spinners -->
                    <input type="text" id="LoanLimit" class="form-control border-primary text-end" placeholder="00"
                           onkeypress="return isNumberKey(event)" />
                </div>
            </div>
            <div class="modal-footer bg-light p-3">
                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4 fw-bold" id="btnSave">
                    <i class="fa fa-save me-1"></i> Save Data
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/master_configuration.js" asp-append-version="true"></script>
}
