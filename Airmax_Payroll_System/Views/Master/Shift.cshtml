<!-- ADD / EDIT MODAL -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title">Shift Master</h4>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="entryForm">

                    <input type="hidden" id="IDShift" value="0" />

                    <div class="row g-3">

                        <!-- Department -->
                        <div class="col-md-6">
                            <label class="form-label">Department</label>
                            <select id="IDDepartment" class="form-control">
                                <option value="">Select Department</option>
                            </select>
                        </div>

                        <!-- Shift Description -->
                        <div class="col-md-6">
                            <label class="form-label">Shift Description</label>
                            <input type="text"
                                   class="form-control"
                                   id="ShiftDesc"
                                   placeholder="Morning / Evening / Night">
                        </div>

                        <!-- Start Time -->
                        <div class="col-md-3">
                            <label class="form-label">Start Time</label>
                            <div class="input-group clockpicker">
                                <input type="text"
                                       class="form-control"
                                       id="StartTime"
                                       placeholder="HH:mm">
                                <span class="input-group-text">
                                    <i class="far fa-clock"></i>
                                </span>
                            </div>
                        </div>

                        <!-- End Time -->
                        <div class="col-md-3">
                            <label class="form-label">End Time</label>
                            <div class="input-group clockpicker">
                                <input type="text"
                                       class="form-control"
                                       id="EndTime"
                                       placeholder="HH:mm">
                                <span class="input-group-text">
                                    <i class="far fa-clock"></i>
                                </span>
                            </div>
                        </div>

                        <!-- Total Working Hour (Auto) -->
                        <div class="col-md-3">
                            <label class="form-label">Total Working Hour</label>
                            <input type="text"
                                   class="form-control"
                                   id="WorkingHour"
                                   readonly>
                        </div>

                        <!-- Total Working Minute (Auto) -->
                        <div class="col-md-3">
                            <label class="form-label">Total Working Minute</label>
                            <input type="text"
                                   class="form-control"
                                   id="WorkingMinute"
                                   readonly>
                        </div>

                        <!-- Overtime -->
                        <div class="col-md-3">
                            <label class="form-label">Overtime</label>
                            <div class="input-group clockpicker">
                                <input type="text"
                                       class="form-control"
                                       id="EndTime"
                                       placeholder="HH:mm">
                                <span class="input-group-text">
                                    <i class="far fa-clock"></i>
                                </span>
                            </div>
                        </div>

                        <!-- Remarks -->
                        <div class="col-md-6">
                            <label class="form-label">Remarks</label>
                            <input type="text"
                                   class="form-control"
                                   id="Remarks">
                        </div>

                    </div>

                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-primary" id="btnSave">
                    Save
                </button>
            </div>

        </div>
    </div>
</div>

