@{
    // ViewBag.Title = "Employee Group Master";
    ViewBag.Title = "Group Bonus Details";
}

<div class="row">
    <div class="col-12">
        <div class="card">

            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Employee Group Master</h4>

                <a data-bs-toggle="modal"
                   data-bs-target="#addModal"
                   class="btn btn-primary btn-sm">
                    Add Employee Group
                </a>
            </div>

            <div class="table-responsive">
                <table id="groupList"
                       class="display table-hover table-striped w-100">

                    <thead class="table-primary">
                        <tr>
                            <th>Group Name</th>
                            <th>Department</th>
                            <th style="width:2%">Action</th>
                        </tr>
                    </thead>

                    <tbody id="tblBody"></tbody>

                </table>
            </div>

        </div>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title">Employee Group</h4>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="entryForm">

                    <input type="hidden" id="IDEmployeeGroup" value="0" />

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Department</label>
                            <select id="IDDepartment" class="form-control"></select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Group Name</label>
                            <input type="text" id="EmployeeGroupName" class="form-control">
                        </div>


                        <div class="col-md-4">
                            <label class="form-label">Active</label>
                            <div class="form-check mt-2">
                                <input type="checkbox" id="IsActive" class="form-check-input" checked>
                                <label class="form-check-label">Is Active</label>
                            </div>
                        </div>

                    </div>

                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="btnSave">Save</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/employeegroup.js"></script>
}