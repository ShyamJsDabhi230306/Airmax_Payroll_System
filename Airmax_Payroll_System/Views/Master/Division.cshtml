@{
    ViewBag.Title = "Division Master";
}

<div class="row">
    <div class="col-12">
        <div class="card">

            <div class="card-header">
                <h4 class="card-title">Division Master</h4>

                <!-- added id="btnAdd" and class "btn-add" for security rights -->
                <a id="btnAdd"
                   data-bs-toggle="modal"
                   data-bs-target="#addModal"
                   class="btn btn-primary btn-sm btn-add">
                    Add Division
                </a>
            </div>

            <div class="table-responsive">

                <table id="divisionList"
                       class="table table-striped table-hover w-100">

                    <thead class="table-primary">
                        <tr>
                            <th>Location</th>
                            <th>Division Name</th>
                            <th>Remarks</th>
                            <th style="width:120px">Action</th>
                        </tr>
                    </thead>

                    <tbody id="tblBody"></tbody>

                </table>

            </div>

        </div>
    </div>
</div>


<!-- MODAL -->

<div class="modal fade" id="addModal" tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">Division Master</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>


            <div class="modal-body">

                <form id="entryForm">

                    <input type="hidden" id="IDDivision" value="0" />

                    <div class="row g-3">

                        <div class="col-md-12">
                            <label class="form-label">Location</label>

                            <select id="IDLocation" class="form-control">
                                <option value="">Select Location</option>
                            </select>
                        </div>


                        <div class="col-md-12">
                            <label class="form-label">Division Name</label>

                            <input type="text"
                                   id="DivisionName"
                                   class="form-control"
                                   placeholder="Enter Division Name" />
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Remarks</label>

                            <textarea id="Remarks"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Enter Remarks"></textarea>
                        </div>

                    </div>

                </form>

            </div>


            <div class="modal-footer">

                <button class="btn btn-light"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <!-- added id="btnSave" class "btn-save" for security rights -->
                <button class="btn btn-primary btn-save"
                        id="btnSave">
                    Save
                </button>

            </div>

        </div>
    </div>
</div>


@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/division.js"></script>
}
