@{
    ViewData["Title"] = "User Access Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* 💎 PREMIUM TABLE SCROLLING */
    .rights-container {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
    }

    /* Fixed Header area */
    .table-head-fixed {
        overflow-y: scroll; /* Forces scrollbar visibility to keep alignment */
        background: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    /* Scrollable Body area */
    .table-body-scrollable {
        max-height: 450px;
        overflow-y: scroll;
    }

    .rights-table {
        table-layout: fixed; /* ⚡ CRITICAL: Keeps header & body aligned */
        width: 100%;
        margin-bottom: 0;
        border-collapse: collapse;
    }

    /* 📏 EXACT COLUMN WIDTHS */
    .col-name {
        width: 40%;
        text-align: left;
        padding-left: 15px !important;
    }

    .col-check {
        width: 15%;
        text-align: center;
    }

    .rights-table th {
        background-color: #eef5ff !important;
        color: #333;
        font-weight: 700;
        padding: 12px 5px !important;
        border: 1px solid #dee2e6;
    }

    .rights-table td {
        padding: 10px 5px !important;
        border: 1px solid #eee;
        vertical-align: middle;
    }

    /* Checkbox Styling */
    .chk-premium {
        width: 20px;
        height: 20px;
        cursor: pointer;
        accent-color: #0d6efd;
    }

</style>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 border-bottom">
        <h4 class="mb-0 fw-bold text-primary"><i class="fa fa-user-shield me-2"></i>User Access Management</h4>
    </div>

    <div class="card-body">
        <!-- 🎯 DROPDOWNS -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <label class="form-label fw-bold small">Company</label>
                <select id="ddlCompany" class="form-control selectpicker" data-live-search="true" data-container="body">
                    <option value="0">Select Company...</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small">Location</label>
                <select id="ddlLocation" class="form-control selectpicker" data-live-search="true" data-container="body" disabled>
                    <option value="0">Select Location...</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small">Department</label>
                <select id="ddlDepartment" class="form-control selectpicker" data-live-search="true" data-container="body" disabled>
                    <option value="0">Select Department...</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small">Select User</label>
                <select id="ddlUser" class="form-control selectpicker" data-live-search="true" data-container="body" disabled>
                    <option value="0">Select User...</option>
                </select>
            </div>
        </div>

        <div id="permissionsGridWrapper" style="display:none;">
            <div class="rights-container">
                <!-- 1. HEADER SECTION -->
                <div class="table-head-fixed">
                    <table class="rights-table">
                        <thead>
                            <tr>
                                <th class="col-name">Page Name</th>
                                <th class="col-check">View <br /><input type="checkbox" id="selectAllView" class="chk-premium" /></th>
                                <th class="col-check">Create <br /><input type="checkbox" id="selectAllCreate" class="chk-premium" /></th>
                                <th class="col-check">Edit <br /><input type="checkbox" id="selectAllEdit" class="chk-premium" /></th>
                                <th class="col-check">Delete <br /><input type="checkbox" id="selectAllDelete" class="chk-premium" /></th>
                            </tr>
                        </thead>
                    </table>
                </div>

                <!-- 2. SCROLLABLE BODY SECTION -->
                <div class="table-body-scrollable">
                    <table id="tblPermissions" class="rights-table table-hover table-striped">
                        <tbody></tbody>
                    </table>
                </div>
            </div>

            <!-- 3. FIXED BUTTON BAR -->
            <div class="mt-3 p-3 bg-light rounded d-flex justify-content-between align-items-center">
                <span class="text-secondary small italic">* Use top checkboxes to select all columns quickly.</span>
                <button type="button" id="btnSaveRights" class="btn btn-primary px-5 shadow">
                    <i class="fa fa-save me-2"></i>Save User Rights
                </button>
            </div>
        </div>

        <!-- Empty State -->
        <div id="noUserSelectedState" class="text-center py-5">
            <h5 class="text-muted"><i class="fa fa-mouse-pointer me-2"></i>Please select a user to load permissions</h5>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/UserRights.js" asp-append-version="true"></script>
}
