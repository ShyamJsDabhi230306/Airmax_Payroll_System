@{
    ViewData["Title"] = "User Access Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* 1. Force the table to behave */
    #tblPermissions {
        table-layout: fixed !important;
        width: 100% !important;
        border-collapse: collapse !important;
    }

    /* 2. Lock column widths */
    .col-name {
        width: 40% !important;
    }

    .col-check {
        width: 15% !important;
    }

    /* 3. Header Styling - Lower Z-Index so Dropdowns appear ABOVE it */
    #tblPermissions thead th {
        background-color: #d1e7ff !important;
        color: #333 !important;
        border: 1px solid #dee2e6 !important;
        vertical-align: middle !important;
        padding: 12px 5px !important;
    }

    .sticky-top {
        z-index: 5 !important; /* Lower than dropdowns (1000) */
    }

    /* 4. Fix Checkbox Look */
    .form-check-input {
        width: 1.25rem;
        height: 1.25rem;
        cursor: pointer;
    }

    #tblPermissions td {
        border: 1px solid #dee2e6 !important;
        vertical-align: middle !important;
    }

    #tblPermissions thead th.col-check {
        text-align: center !important;
    }
</style>

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3 border-bottom">
        <div class="row align-items-center">
            <div class="col">
                <h4 class="mb-1 fw-bold text-primary">User Access Management</h4>
                <p class="text-muted small mb-0">Define granular permissions for system users</p>
            </div>
        </div>
    </div>

    <div class="card-body">
        <!-- Cascading Dropdowns -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <label class="form-label fw-bold small">Company</label>
                <select id="ddlCompany" class="form-control selectpicker show-tick" data-live-search="true">
                    <option value="0">Select Company...</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small">Location</label>
                <select id="ddlLocation" class="form-control selectpicker show-tick" data-live-search="true" disabled>
                    <option value="0">Select Location...</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small">Department</label>
                <select id="ddlDepartment" class="form-control selectpicker show-tick" data-live-search="true" disabled>
                    <option value="0">Select Department...</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small">Select User</label>
                <select id="ddlUser" class="form-control selectpicker show-tick" data-live-search="true" disabled>
                    <option value="0">Select User...</option>
                </select>
            </div>
        </div>

        <hr class="opacity-10" />

        <!-- Permissions Grid (Hidden until user selected) -->
        <div id="permissionsGridWrapper" style="display:none;">
            <div class="table-responsive border rounded-3 overflow-auto" style="max-height: 550px;">
                <table id="tblPermissions" class="table table-hover table-striped mb-0">
                    <thead class="table-primary sticky-top" >
                        <tr >
                            <th class="col-name">Page Name</th>
                            <th class="text-center col-check">
                                View <br />
                                <div class="form-check d-flex justify-content-center m-0">
                                    <input type="checkbox" id="selectAllView" class="form-check-input mt-1" />
                                </div>
                            </th>
                            <th class="text-center col-check">
                                Create <br />
                                <div class="form-check d-flex justify-content-center m-0">
                                    <input type="checkbox" id="selectAllCreate" class="form-check-input mt-1" />
                                </div>
                            </th>
                            <th class="text-center col-check">
                                Edit <br />
                                <div class="form-check d-flex justify-content-center m-0">
                                    <input type="checkbox" id="selectAllEdit" class="form-check-input mt-1" />
                                </div>
                            </th>
                            <th class="text-center col-check">
                                Delete <br />
                                <div class="form-check d-flex justify-content-center m-0">
                                    <input type="checkbox" id="selectAllDelete" class="form-check-input mt-1" />
                                </div>
                            </th>
                        </tr>
                    </thead>

                    <tbody></tbody>
                </table>
            </div>

            <!-- Save Button (Only ONE at the bottom) -->
            <div class="text-right mt-4 p-3 bg-light border-top rounded" style="display:flex;justify-content:right">
                <button type="button" id="btnSaveRights" class="btn btn-primary px-5 btn-lg shadow-sm">
                    <i class="fa fa-save me-2"></i> Save User Rights
                </button>
            </div>
        </div>

        <!-- Empty State (Shown until user selected) -->
        <div id="noUserSelectedState" class="text-center py-5">
            <i class="fa fa-user-lock text-muted mb-3" style="font-size: 60px; opacity: 0.2;"></i>
            <h5 class="text-muted">User Selection Required</h5>
            <p class="text-muted small">Choose a user from the dropdown above to manage their access rights.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/UserRights.js" asp-append-version="true"></script>
}
