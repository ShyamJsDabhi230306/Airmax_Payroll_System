@{
    ViewBag.Title = "Department Master";
}

<div class="row">
    <div class="col-12">
        <div class="card">

            <div class="card-header">
                <h4 class="card-title">Department Master</h4>

                <a data-bs-toggle="modal"
                   data-bs-target="#addModal"
                   class="btn btn-primary btn-sm">
                    Add Department
                </a>
            </div>

            <div class="table-responsive">

                <table id="departmentList"
                       class="table table-striped table-hover w-100">

                    <thead class="table-primary">
                        <tr>
                            <th>Location</th>
                            <th>Department Name</th>
                            <th style="width:120px">Action</th>
                        </tr>
                    </thead>

                    <tbody id="tblBody"></tbody>

                </table>

            </div>

        </div>
    </div>
</div>



<!-- MODAL -->

<div class="modal fade" id="addModal" tabindex="-1">

    <div class="modal-dialog modal-lg modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">Department Master</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>


            <div class="modal-body">

                <form id="entryForm">

                    <input type="hidden" id="IDDepartment" value="0" />

                    <div class="row g-3">

                        <div class="col-md-12">
                            <label class="form-label">Location</label>

                            <select id="IDLocation" class="form-control">
                                <option value="">Select Location</option>
                            </select>
                        </div>


                        <div class="col-md-12">
                            <label class="form-label">Department Name</label>

                            <input type="text"
                                   id="DepartmentName"
                                   class="form-control"
                                   placeholder="Enter Department Name" />
                        </div>

                    </div>

                </form>

            </div>


            <div class="modal-footer">

                <button class="btn btn-light"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-primary"
                        id="btnSave">
                    Save
                </button>

            </div>

        </div>
    </div>
</div>


@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/department.js"></script>
}