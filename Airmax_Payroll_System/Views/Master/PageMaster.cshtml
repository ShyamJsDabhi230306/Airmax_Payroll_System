@{
    ViewBag.Title = "Page Master";
}

<div class="row">
    <div class="col-12">
        <div class="card">

            <div class="card-header">
                <h4 class="card-title">Page Master</h4>

                <a data-bs-toggle="modal"
                   data-bs-target="#addModal"
                   class="btn btn-primary btn-sm btn-add">
                    Add New Page
                </a>
            </div>

            <div class="table-responsive">
                <table id="pageList" class="display table-hover table-striped w-100">
                    <thead class="table-primary">
                        <tr>
                            <th>Page Name</th>
                            <th>URL Prefix</th>
                            <th class="text-center" style="width:10%">Status</th>
                            <th class="text-center" style="width:2%">Action</th>
                        </tr>
                    </thead>
                    <tbody id="tblBody">
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- ADD / EDIT MODAL -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title">Page Master</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="entryForm">
                    <input type="hidden" id="PageId" value="0" />

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label">Display Name</label>
                            <input type="text" id="PageName" class="form-control" placeholder="Enter Page Name">
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">URL Prefix</label>
                            <input type="text" id="PageUrl" class="form-control" placeholder="Enter URL Prefix (e.g. /master/page)">
                        </div>

                        <div class="col-md-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="IsActive" checked>
                                <label class="form-check-label ms-2" for="IsActive">Active Status</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="btnSave">Save</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/PageMaster.js" asp-append-version="true"></script>
}
