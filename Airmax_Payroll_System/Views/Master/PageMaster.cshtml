@{
    ViewBag.Title = "Page Master";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0 fw-bold text-primary">Page Master</h4>
                <a data-bs-toggle="modal" data-bs-target="#addModal" class="btn btn-primary btn-sm px-4 shadow">
                    <i class="fa fa-plus me-1"></i> Add Page
                </a>
            </div>

            <div class="table-responsive p-3">
                <!-- Standard Bootstrap Table without fixed height to match your perfect pages -->
                <table id="pageList" class="display table-hover table-striped w-100">
                    <thead class="table-primary">
                        <tr>
                            <th style="width: 50px;">ID</th>
                            <th>Page Name</th>
                            <th>URL Prefix</th>
                            <th class="text-center" style="width: 100px;">Status</th>
                            <th class="text-center" style="width: 100px;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="tblBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow border-0">
            <div class="modal-header border-bottom">
                <h4 class="modal-title fw-bold">Maintain Page Master</h4>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="entryForm">
                    <input type="hidden" id="PageId" value="0" />
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Page Display Name</label>
                        <input type="text" id="PageName" class="form-control py-2" placeholder="e.g. Employee Master" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Security URL Prefix</label>
                        <input type="text" id="PageUrl" class="form-control py-2" placeholder="e.g. /master/employee" required />
                    </div>
                    <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" id="IsActive" checked>
                        <label class="form-check-label ms-2" for="IsActive">Status Active</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top bg-light">
                <button class="btn btn-light" data-bs-dismiss="modal">Close</button>
                <button class="btn btn-primary" id="btnSave">Save Page</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/PageMaster.js" asp-append-version="true"></script>
}
