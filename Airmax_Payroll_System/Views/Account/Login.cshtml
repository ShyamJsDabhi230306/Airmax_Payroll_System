@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="en">

<head>
    <!-- PAGE TITLE HERE -->
    <base href="~/" />
    <title> Sign In | Airmax Payroll Portal</title>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    <!-- AUTHOR & SEO -->
    <meta name="author" content="LNX Infotech Pvt. Ltd.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://Airmax.lnxinfotech.com">

    <meta name="keywords"
          content="Airmax Portal, Design Requisition Slip, Design Workflow Management, Engineering Design Portal,
                   Approval Workflow System, Manufacturing Design Requests, LNX Infotech Pvt Ltd">

    <meta name="description"
          content="Airmax Portal by LNX Infotech Pvt. Ltd. is a centralized Design Requisition Slip management system
                   for streamlined approvals, task assignments, and SLA-based design workflows.">

    <!-- OPEN GRAPH -->
    <meta property="og:title" content="Airmax Portal | LNX Infotech Pvt. Ltd.">
    <meta property="og:description"
          content="Manage Design Requisition Slips, approvals, and designer tasks efficiently using Airmax Portal by LNX Infotech Pvt. Ltd.">
    <meta property="og:image" content="https://Airmax.lnxinfotech.com/assets/og-image.png">
    <meta property="og:type" content="website">

    <!-- TWITTER -->
    <meta name="twitter:title" content="Airmax Portal | LNX Infotech Pvt. Ltd.">
    <meta name="twitter:description"
          content="Airmax Portal helps organizations manage design requests, approvals, and SLA-driven tasks efficiently.">
    <meta name="twitter:image" content="https://Airmax.lnxinfotech.com/assets/og-image.png">
    <meta name="twitter:card" content="summary_large_image">

    <!-- MOBILE -->
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="format-detection" content="telephone=no">

    <!-- FAVICON -->
    <link rel="shortcut icon" type="image/png" href="~/images/favicon.png">

    <!-- STYLES -->
    <link href="~/vendor/bootstrap-select/css/bootstrap-select.min.css" rel="stylesheet">
    <link class="main-css" href="~/css/style.css" rel="stylesheet">
</head>


<body>
    <div class="authincation d-flex flex-column flex-lg-row flex-column-fluid">
        <div class="login-aside text-center d-none d-sm-flex flex-column flex-row-auto">
            <div class="d-flex flex-column-auto flex-column pt-lg-40 pt-15">
                <div class="text-center mb-4 pt-2">
                    <a href="#"><img src="~/aira.png" class="dark-login w-25" alt="AIRA"></a>
                    <a href="#"><img src="~/aira.png" class="light-login" alt="AIRA"></a>
                </div>
                <h3 class="mb-2">Welcome to Airmax Portal</h3>

                <p class="text-muted px-3">
                    A centralized Design Requisition Slip system to manage design requests,
                    approvals, task assignments, and SLA-driven workflows efficiently.
                </p>
            </div>
            <div class="aside-image" style="background-image:url(images/pic1.svg);"></div>
        </div>
        <div class="container flex-row-fluid d-flex flex-column justify-content-center position-relative overflow-hidden p-7 mx-auto">
            <div class="d-flex justify-content-center h-100 align-items-center">
                <div class="authincation-content style-2">
                    <div class="row no-gutters">
                        <div class="col-xl-12">
                            <div class="auth-form">
                                <div class="text-center d-block d-sm-none mb-4 pt-5">
                                    <a href="#"><img src="~/aira.png" class="dark-login w-25" alt="AIRA"></a>
                                    <a href="#"><img src="~/aira.png" class="light-login w-25" alt="AIRA"></a>
                                </div>

                                <h4 class="text-center mb-4">Sign in your account</h4>
                                <form action="index.html">
                                    <div class="mb-3">
                                        <label class="mb-1 form-label">UserName</label>
                                        <input type="text"
                                               id="ic-username"
                                               class="form-control"
                                               placeholder="Enter your UserName">
                                    </div>
                                    <div class="mb-3">
                                        <label class="mb-1 form-label">Password</label>
                                        <div class="position-relative">
                                            <input type="password"
                                                   id="ic-password"
                                                   class="form-control"
                                                   placeholder="Enter your password">
                                            <span class="show-pass eye">
                                                <i class="fa fa-eye-slash"></i>
                                                <i class="fa fa-eye"></i>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="form-row d-flex justify-content-between mt-4 mb-2">
                                        <div class="mb-3">
                                            <div class="form-check custom-checkbox ms-1">
                                                <input type="checkbox" class="form-check-input" id="basic_checkbox_1">
                                                <label class="form-check-label" for="basic_checkbox_1">Remember my preference</label>
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <a href="#">Forgot Password?</a>
                                        </div>
                                    </div>
                                    <div class="text-center">
                                        <button type="submit" class="btn btn-primary btn-block">Sign Me In</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!--**********************************
        Scripts
    ***********************************-->
    <!-- Required vendors -->
    <script src="~/vendor/global/global.min.js"></script>
    <script src="~/vendor/bootstrap-select/js/bootstrap-select.min.js"></script>
    <script src="~/js/custom.min.js"></script>
    <script src="~/js/ic-sidenav-init.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @* <script src="~/AirmaxPayRollJS/a/" asp-append-version="true"></script> *@
    <script src="~/airmaxpayrolljs/account/login.js" asp-append-version="true"></script>
    <script>
        history.pushState(null, "", location.href);
        window.onpopstate = function () {
            history.go(1);
        };

        // Show message from query string if present (Spec Requirement #5)
        document.addEventListener("DOMContentLoaded", function() {
            const params = new URLSearchParams(window.location.search);
            const msg = params.get("message");
            if (msg) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Access Restricted',
                    text: msg,
                    confirmButtonText: 'Understood'
                });
            }
        });
    </script>

</body>
</html>