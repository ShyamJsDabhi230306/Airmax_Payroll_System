@using Airmax_Payroll_System.Services
@inject UserRightsService _rightsService
@{
    // 🛡️ SERVER-SIDE SECURITY GUARD (PERMANENT FIX)
    var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    int userId = int.TryParse(userIdClaim, out var id) ? id : 0;
    var userRole = (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "").ToLower();
    bool isAdmin = userRole == "admin" || userRole == "administrator";

    // Fetch permissions from the SP you provided (backend)
    var permissions = userId > 0 ? await _rightsService.GetPermissionsAsync(userId) : new List<Airmax_Payroll_System.Models.Master.UserPagePermission>();

    // Helper to check if user has view right for a page name
    // bool HasRight(string pageName) => isAdmin || permissions.Any(p => p.PageName.Trim().Equals(pageName, StringComparison.OrdinalIgnoreCase) && p.CanView);

    // Current page permissions for the CSS Shield
    // var currentPageTitle = ViewBag.Title as string ?? "";
    // var currentRight = permissions.FirstOrDefault(p => p.PageName.Trim().Equals(currentPageTitle, StringComparison.OrdinalIgnoreCase));

    // 🛡️ Helper to check rights by Page Name (used for Sidebar)
bool HasRight(string pageName) => isAdmin || permissions.Any(p => p.PageName.Trim().Equals(pageName, StringComparison.OrdinalIgnoreCase) && p.CanView);

// 🛡️ PERFECT MATCH: Instead of Title, we use the URL to find permissions
// This ensures Add/Edit/Delete buttons are hidden even if you mistype the Title.
var currentUrl = Context.Request.Path.Value?.ToLower().TrimEnd('/') ?? "";
var currentRight = permissions.FirstOrDefault(p => 
    !string.IsNullOrEmpty(p.PageUrl) && 
    (currentUrl.EndsWith(p.PageUrl.ToLower().TrimEnd('/')) || p.PageUrl.ToLower().Contains(currentUrl))
);

// Fallback: If URL match fails, try Title as a backup
if (currentRight == null) {
    var currentPageTitle = ViewBag.Title as string ?? "";
    currentRight = permissions.FirstOrDefault(p => p.PageName.Trim().Equals(currentPageTitle, StringComparison.OrdinalIgnoreCase));
}



}
