@{
    ViewBag.Title = "Division Kharchi Entry";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-0 text-primary fw-bold">Division Kharchi Entry</h5>
            <small class="text-muted">Manage department-wise kharchi for selected month</small>
        </div>
        <div class="d-flex gap-2">
            <a href="/Transaction/EmployeeKharchiList" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                <i class="fas fa-history me-1"></i> Kharchi List
            </a>
            <button type="button" class="btn btn-outline-primary fw-bold shadow-sm" onclick="printKharchiReport()">
                <i class="fas fa-print me-1"></i> PRINT SELECTED
            </button>
            <button type="button" class="btn btn-outline-success fw-bold shadow-sm" onclick="exportKharchiToExcel()">
                <i class="fas fa-file-excel me-1"></i> EXCEL
            </button>
        </div>
    </div>

    <div class="card-body">
        <!-- TOP FILTER BAR -->
        <div class="row g-3 mb-4 bg-light p-3 rounded mx-0 border">
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Month & Year</label>
                <input type="month" id="txtKharchiDate" class="form-control form-control-sm border-primary" onchange="loadDivisionsForMonth()" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Voucher No (Auto)</label>
                <input type="text" id="txtKharchiNo" class="form-control form-control-sm text-center fw-bold bg-white" readonly placeholder="---" />
            </div>
            <div class="col-md-6 text-end pt-4">
                <span class="badge bg-soft-info text-info p-2 px-3">
                    <i class="fas fa-info-circle me-1"></i> Each division has a unique voucher per month
                </span>
            </div>
        </div>

        <!-- MAIN DIVISION GRID -->
        <div class="table-responsive">
            <table class="table table-hover align-middle border mb-0">
                <thead class="bg-light">
                    <tr class="small text-muted text-uppercase">
                        <th width="50" class="text-center">
                            <!-- 🔥 Select All Checkbox -->
                            <input type="checkbox" class="form-check-input" id="chkSelectAllDivs" onclick="selectAllDivs(this)" />
                        <th width="60" class="text-center">EXP</th>
                        <th>DIVISION NAME</th>
                        <th class="text-center">TOTAL DEPARTMENTS</th>
                        <th width="200" class="text-end pe-4">ACTION</th>
                    </tr>
                </thead>
                <tbody id="tblDivisionBody">
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="text-muted">
                                <i class="fas fa-calendar-alt fa-3x mb-3 opacity-25"></i>
                                <p>Please select a Month & Year to display Divisions</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- POPUP MODAL: Employee List for Specific Department -->

<div class="modal fade" id="kharchiModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered " >

       @* max-width: 90% *@
        <div class="modal-content border-0 shadow-lg">
            <!-- Inside <div class="modal-body p-0">, above the table responsive div -->
            <div class="bg-white p-3 border-bottom d-flex align-items-center gap-3 shadow-sm">
                <div style="width: 250px;">
                    <label class="extra-small fw-bold text-muted text-uppercase mb-1 d-block" style="font-size:0.65rem">Bulk Amount (Apply to All)</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-primary text-white border-0">₹</span>
                        <input type="number" id="txtBulkAmount" class="form-control border-primary" placeholder="Enter amount..." />
                    </div>
                </div>
                <div class="pt-3">
                    <button type="button" class="btn btn-primary btn-sm px-3 fw-bold shadow-sm" onclick="applyBulkAmount()">
                        <i class="fas fa-check-double me-1"></i> APPLY TO ALL
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm px-3 fw-bold ms-2" onclick="clearAllAmounts()">
                        <i class="fas fa-eraser me-1"></i> CLEAR ALL
                    </button>
                </div>
            </div>

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title d-flex align-items-center ">
                    <i class="fas fa-users-cog me-2"></i>
                    <span id="modalTitle" style="color: white !important;">Department Kharchi List</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 ">
                <div class="bg-light p-2 px-3 border-bottom d-flex justify-content-between align-items-center">
                    <small class="text-muted" id="modalSubTitle">Enter amounts for employees</small>
                    <span class="badge bg-primary" id="lblCount">0 Employees</span>
                </div>
                <div class="table-responsive" style="max-height: 50vh;">
                    <table class="table table-sm table-hover mb-0 align-middle">
                        <thead class="bg-white sticky-top shadow-sm">
                            <tr class="small text-muted text-uppercase">
                                <th class="ps-3 py-2">Employee Details</th>
                                <th>Status</th>
                                <th width="140">Amount (₹)</th>
                                @* <th width="180">Remark</th> *@
                            </tr>
                        </thead>
                        <tbody id="tblEmployeeBody">
                            <!-- Rows injected by JS -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-light border-top-0">
                <div class="me-auto">
                    <small class="text-muted d-block">Department Total</small>
                    <h5 class="mb-0 fw-bold text-success" id="lblDeptTotal">₹ 0.00</h5>
                </div>
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="saveDepartmentData()">
                    <i class="fas fa-save me-1"></i> SAVE DEPARTMENT
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/employee_kharchi_entry.js" asp-append-version="true"></script>

    <script src="~/AirmaxPayRollJS/Transaction/kharchi_print_report.js" asp-append-version="true"></script>


}

<style>
    .bg-soft-info {
        background-color: #e0f7fa;
    }

    .text-info {
        color: #00acc1 !important;
    }

    .bg-soft-primary {
        background-color: #e8eaf6;
    }

    .btn-xs {
        padding: 0.1rem 0.4rem;
        font-size: 0.75rem;
    }

    .modal-lg {
        max-width: 900px;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    /* Hide arrows in Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>
