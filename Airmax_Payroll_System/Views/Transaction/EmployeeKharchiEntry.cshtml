@* 
   📝 FILE 4: EmployeeKharchiEntry.cshtml 
   Location: Views/Transaction/EmployeeKharchiEntry.cshtml
*@
@{
    ViewBag.Title = "Division Kharchi Entry";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <div><h5 class="mb-0 text-primary fw-bold">Division Kharchi Entry</h5></div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-info btn-sm fw-bold px-3" onclick="printKharchi()"><i class="fas fa-print me-1"></i> PRINT REPORT</button>
            <a href="/Transaction/EmployeeKharchiList" class="btn btn-outline-secondary btn-sm px-3">View History</a>
        </div>
    </div>

    <div class="card-body">
        <div class="row g-3 mb-4 bg-light p-3 rounded">
            <div class="col-md-2">
                <label class="form-label small fw-bold text-muted text-uppercase">Voucher No</label>
                <input type="text" id="txtKharchiNo" class="form-control form-control-sm text-center fw-bold" readonly placeholder="---" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Month & Year</label>
                <input type="month" id="txtKharchiDate" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-bold text-muted text-uppercase">Select Division</label>
                <select id="ddlDivision" class="form-select form-select wide"></select>
            </div>


            <div class="col-md-3 d-grid" style="height:35px;margin-top:45px;">
                <button type="button" class="btn btn-primary btn-sm fw-bold" onclick="btnLoadEmployees()">LOAD DEPARTMENTS</button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr class="small text-muted text-uppercase">
                        <th width="50" class="text-center">EXP</th>
                        <th width="50" class="text-center">SEL</th>
                        <th>DEPARTMENT NAME</th>
                        <th colspan="2"></th>
                        <th width="180" class="text-end pe-4">DEPT TOTAL</th>
                        <th width="50"></th>
                    </tr>
                </thead>
                <tbody id="tblBody">
                    <tr><td colspan="7" class="text-center py-5">Select Division and click Load</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer bg-white border-top p-4 d-flex justify-content-between align-items-center">
        <div class="d-flex gap-5">
            <div><small class="text-muted d-block small ls-1">ENTRIES</small><h5 id="lblSelected" class="mb-0 fw-bold">0</h5></div>
            <div><small class="text-success d-block small ls-1">GRAND TOTAL</small><h4 id="lblTotal" class="mb-0 fw-bold text-success">₹ 0.00</h4></div>
        </div>
        <button class="btn btn-success px-5 fw-bold rounded-pill" onclick="saveData()">SAVE CHANGES</button>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/kharchi_print.js" asp-append-version="true"></script>
    <script src="~/AirmaxPayRollJS/Transaction/employee_kharchi_entry.js" asp-append-version="true"></script>
}
