@{
    ViewBag.Title = "Attendance Logs Fetcher";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-white"><i class="fas fa-file-invoice me-2"></i>Fetch & Save Attendance Logs</h5>
        </div>
        <div class="card-body">
            <!-- Filtering controls -->
            <div class="row g-3 mb-4 align-items-end">

                <div class="col-xl-4 col-lg-4 col-md-6">
                    <label class="form-label fw-semibold text-dark">
                        <i class="fas fa-calendar-alt me-2 text-primary"></i>Attendance Month
                    </label>
                    <input type="month"
                           id="filterMonth"
                           class="form-control form-control-lg"
                           value="@DateTime.Now.ToString("yyyy-MM")">
                </div>

                <div class="col-xl-4 col-lg-4 col-md-6">
                    <label class="form-label fw-semibold text-dark">
                        <i class="fas fa-search me-2 text-primary"></i>Search
                    </label>
                    <input type="text"
                           id="globalSearch"
                           class="form-control form-control-lg"
                           placeholder="Search anything..."
                           onkeyup="applyGlobalFilter()">
                </div>

                <div class="col-xl-2 col-lg-2 col-md-6">
                    <button class="btn btn-primary btn-lg w-100 fw-bold shadow-sm"
                            onclick="fetchLogs()">
                        <i class="fas fa-download me-2"></i>
                        Fetch
                    </button>
                </div>

                <div class="col-xl-2 col-lg-2 col-md-6">
                    <button class="btn btn-success btn-lg w-100 fw-bold shadow-sm"
                            id="btnSave"
                            onclick="saveLogs()"
                            disabled>
                        <i class="fas fa-save me-2"></i>
                        Save
                    </button>
                </div>

            </div>

            <!-- Grid container -->
            <div class="table-responsive overflow-auto border rounded w-100" style="max-height: 550px; max-width: 100%;">
                <table class="table table-hover table-striped border align-middle small mb-0 text-nowrap" id="tblLogs">
                    <thead class="table-light text-uppercase">
                        <tr>
                            <th style="position: sticky; top: 0; z-index: 1;">Employee Code</th>
                            <th style="position: sticky; top: 0; z-index: 1;">Employee Name</th>
                            <th style="position: sticky; top: 0; z-index: 1;">Date</th>
                            <th style="position: sticky; top: 0; z-index: 1;">In Time</th>
                            <th style="position: sticky; top: 0; z-index: 1;">Out Time</th>
                            <th style="position: sticky; top: 0; z-index: 1;">Total Working</th>
                            <th style="position: sticky; top: 0; z-index: 1;">Late</th>
                            <th style="position: sticky; top: 0; z-index: 1;">OT</th>
                            <th style="position: sticky; top: 0; z-index: 1;">Status</th>
                            <th style="position: sticky; top: 0; z-index: 1;">In Device</th>
                            <th style="position: sticky; top: 0; z-index: 1;">Out Device</th>
                            <th style="position: sticky; top: 0; z-index: 1;">Temp State</th>
                        </tr>
                    </thead>
                    <tbody id="tblLogsBody">
                        <tr>
                            <td colspan="12" class="text-center text-muted py-4">
                                No records loaded. Select a month and click Fetch.
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/attendance_log.js" asp-append-version="true"></script>
}
