@{
    ViewBag.Title = "Attendance Logs Fetcher";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-white">
                <i class="fas fa-file-invoice me-2"></i>Attendance Logs
            </h5>
        </div>

        <div class="card-body overflow-hidden">

            <ul class="nav nav-tabs mb-3" id="attendanceTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active"
                            id="raw-tab"
                            data-bs-toggle="tab"
                            data-bs-target="#rawAttendanceTab"
                            type="button"
                            role="tab">
                        Raw Attendance Logs
                    </button>
                </li>

                <li class="nav-item" role="presentation">
                    <button class="nav-link"
                            id="calculated-tab"
                            data-bs-toggle="tab"
                            data-bs-target="#calculatedAttendanceTab"
                            type="button"
                            role="tab">
                        Calculated Attendance
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link"
                            id="manual-edit-tab"
                            data-bs-toggle="tab"
                            data-bs-target="#manualEditAttendanceTab"
                            type="button"
                            role="tab">
                        Manual Edit
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="attendanceTabsContent">

                <!-- RAW TAB -->
                <div class="tab-pane fade show active"
                     id="rawAttendanceTab"
                     role="tabpanel"
                     aria-labelledby="raw-tab">

                    <div class="row g-2 mb-3 align-items-end">
                        <div class="col-xl-3 col-lg-3 col-md-6">
                            <label class="form-label fw-semibold text-dark mb-1">
                                <i class="fas fa-calendar-alt me-2 text-primary"></i>Attendance Month
                            </label>
                            <input type="month"
                                   id="filterMonth"
                                   class="form-control"
                                   value="@DateTime.Now.ToString("yyyy-MM")">
                        </div>

                        <div class="col-xl-4 col-lg-4 col-md-6">
                            <label class="form-label fw-semibold text-dark mb-1">
                                <i class="fas fa-search me-2 text-primary"></i>Search
                            </label>
                            <input type="text"
                                   id="globalSearch"
                                   class="form-control"
                                   placeholder="Search raw logs..."
                                   onkeyup="applyRawFilter()">
                        </div>

                        <div class="col-xl-5 col-lg-5 col-md-12 text-end">
                            <button class="btn btn-primary btn-sm me-2"
                                    onclick="fetchLogs()">
                                <i class="fas fa-download me-1"></i>
                                Fetch
                            </button>

                            <button class="btn btn-success btn-sm"
                                    id="btnSave"
                                    onclick="saveLogs()"
                                    disabled>
                                <i class="fas fa-calculator me-1"></i>
                                Save & Calculate
                            </button>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label for="rawPageSize" class="mb-0 small text-muted">Show</label>

                        <select id="rawPageSize"
                                class="form-control form-control-sm"
                                style="width: 80px;"
                                onchange="changeRawPageSize()">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100" selected>100</option>
                        </select>

                        <span class="small text-muted">entries</span>
                    </div>

                    <div class="table-responsive overflow-auto border rounded w-100  mt-3 " style="max-height: 550px; max-width: 100%;">

                        <table class="table table-hover table-striped border align-middle small mb-0 text-nowrap" id="tblRawLogs">

                            <thead class="table-light text-uppercase">
                                <tr>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Employee Code</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Log Date Time</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Device Serial</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Direction</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Temp</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Temp State</th>
                                </tr>
                            </thead>
                            <tbody id="tblLogsBody">
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        No records loaded. Select a month and click Fetch.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                       

                        <div id="rawFetchInfo" class="small text-muted">
                            No records loaded.
                        </div>

                        <div>
                            <button class="btn btn-primary btn-sm me-2"
                                    onclick="previousRawPage()">
                                Previous
                            </button>

                            <button class="btn btn-primary btn-sm"
                                    onclick="nextRawPage()">
                                Next
                            </button>
                        </div>
                    </div>
                </div>

                <!-- CALCULATED TAB -->
                <div class="tab-pane fade"
                     id="calculatedAttendanceTab"
                     role="tabpanel"
                     aria-labelledby="calculated-tab">

                    <div class="row g-2 mb-3 align-items-end">
                        <div class="col-xl-3 col-lg-3 col-md-6">
                            <label class="form-label fw-semibold text-dark mb-1">
                                <i class="fas fa-calendar-alt me-2 text-primary"></i>Attendance Month
                            </label>
                            <input type="month"
                                   id="calculatedFilterMonth"
                                   class="form-control"
                                   value="@DateTime.Now.ToString("yyyy-MM")">
                        </div>

                        <div class="col-xl-4 col-lg-4 col-md-6">
                            <label class="form-label fw-semibold text-dark mb-1">
                                <i class="fas fa-search me-2 text-primary"></i>Search
                            </label>
                            <input type="text"
                                   id="calculatedSearch"
                                   class="form-control"
                                   placeholder="Search calculated data..."
                                   onkeyup="applyCalculatedFilter()">
                        </div>

                        <div class="col-xl-5 col-lg-5 col-md-12 text-end">
                            <button class="btn btn-info btn-sm me-2"
                                    onclick="fetchCalculatedLogs()">
                                <i class="fas fa-sync-alt me-1"></i>
                                Fetch Calculated
                            </button>

                            <button class="btn btn-warning btn-sm"
                                    onclick="recalculateAttendance()">
                                <i class="fas fa-calculator me-1"></i>
                                Recalculate
                            </button>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <label class="small text-muted mb-0">Show</label>

                            <select id="calculatedPageSize"
                                    class="form-control form-control-sm"
                                    style="width: 80px;"
                                    onchange="changeCalculatedPageSize()">
                                <option value="10">10</option>
                                <option value="25" selected>25</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>

                            <span class="small text-muted">entries</span>
                        </div>
                    </div>

                    <div class="table-responsive overflow-auto border rounded w-100" style="max-height: 550px; max-width: 100%;">
                        <table class="table table-hover table-striped border align-middle small mb-0 text-nowrap" id="tblCalculatedLogs">
                            <thead class="table-light text-uppercase">
                                <tr>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Employee Code</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Employee Name</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Department</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Date</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">In Time</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Out Time</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Total Working</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Late</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">OT</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Status</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">In Device</th>
                                    <th class="position-sticky top-0 bg-light" style="z-index: 1;">Out Device</th>
                                </tr>
                            </thead>
                            <tbody id="tblCalculatedLogsBody">
                                <tr>
                                    <td colspan="12" class="text-center text-muted py-4">
                                        Select a month and click Fetch Calculated Data.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        

                        <div id="calculatedFetchInfo" class="small text-muted">
                            No records loaded.
                        </div>

                        <div>
                            <button class="btn btn-primary btn-sm me-2"
                                    onclick="previousCalculatedPage()">
                                Previous
                            </button>

                            <button class="btn btn-primary btn-sm"
                                    onclick="nextCalculatedPage()">
                                Next
                            </button>
                        </div>
                    </div>
                </div>
                <!-- MANUAL EDIT TAB -->
                <div class="tab-pane fade"
                     id="manualEditAttendanceTab"
                     role="tabpanel"
                     aria-labelledby="manual-edit-tab">

                    <div class="row g-2 mb-3 align-items-end">
                        <div class="col-xl-3 col-lg-3 col-md-6">
                            <label class="form-label fw-semibold text-dark mb-1">
                                <i class="fas fa-calendar-alt me-2 text-primary"></i>Attendance Month
                            </label>
                            <input type="month"
                                   id="manualEditMonth"
                                   class="form-control"
                                   value="@DateTime.Now.ToString("yyyy-MM")">
                        </div>

                        <div class="col-xl-4 col-lg-4 col-md-6">
                            <label class="form-label fw-semibold text-dark mb-1">
                                <i class="fas fa-search me-2 text-primary"></i>Employee Code / Name
                            </label>
                            <input type="text"
                                   id="manualEditSearch"
                                   class="form-control"
                                   placeholder="Search employee code or name...">
                        </div>

                        <div class="col-xl-5 col-lg-5 col-md-12 text-end">
                            <button class="btn btn-primary btn-sm"
                                    onclick="fetchManualEditList()">
                                <i class="fas fa-search me-1"></i>
                                Fetch Employee Attendance
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover table-striped border align-middle small mb-0 text-nowrap" id="tblManualEditLogs">
                            <thead class="table-light text-uppercase">
                                <tr>
                                    <th>Employee Code</th>
                                    <th>Employee Name</th>
                                    <th>Department</th>
                                    <th>Date</th>
                                    <th>In Time</th>
                                    <th>Out Time</th>
                                    <th>Total Working</th>
                                    <th>Late</th>
                                    <th>OT</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="tblManualEditLogsBody">
                                <tr>
                                    <td colspan="11" class="text-center text-muted py-4">
                                        Select month, enter employee code/name and click Fetch.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="manualEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Edit Attendance Time</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="manualEditSummaryId">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Employee</label>
                    <input type="text" id="manualEditEmployeeText" class="form-control" readonly>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Attendance Date</label>
                    <input type="text" id="manualEditDate" class="form-control" readonly>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">In Time</label>
                    <input type="datetime-local" id="manualEditInTime" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Out Time</label>
                    <input type="datetime-local" id="manualEditOutTime" class="form-control">
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary btn-sm"
                        data-bs-dismiss="modal">
                    Close
                </button>

                <button type="button"
                        class="btn btn-primary btn-sm"
                        onclick="saveManualAttendanceTime()">
                    Save Changes
                </button>
            </div>

        </div>
    </div>
</div>
@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/attendance_log.js" asp-append-version="true"></script>
}