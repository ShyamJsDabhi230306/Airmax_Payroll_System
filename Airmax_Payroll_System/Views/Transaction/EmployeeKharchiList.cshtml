@{
    ViewBag.Title = "Division Kharchi History";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-0 text-primary fw-bold">Division Kharchi History</h5>
            <small class="text-muted">View past kharchi vouchers and employee details</small>
        </div>
        <a href="/Transaction/EmployeeKharchiEntry" class="btn btn-primary btn-sm px-4 fw-bold shadow-sm">
            <i class="fas fa-plus-circle me-1"></i> ADD NEW
        </a>
    </div>

    <div class="card-body">
        <!-- FILTER BAR WITH DIVISION, MONTH, AND SEARCH -->
        <div class="row g-3 mb-4 bg-light p-3 rounded mx-0 border shadow-sm align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted text-uppercase mb-1">Division</label>
                <select id="ddlDivisionFilter" class="form-select border-primary shadow-sm" onchange="loadHistory()">
                    <option value="0">All Divisions</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted text-uppercase mb-1">Month & Year</label>
                <input type="month" id="txtMonthFilter" class="form-control border-primary shadow-sm" onchange="loadHistory()" />
            </div>
            <div class="col-md-6">
                <label class="form-label small fw-bold text-muted text-uppercase mb-1">Search Filter</label>
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white border-primary"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" id="txtSearchFilter" class="form-control border-primary" placeholder="Search voucher number or employee..." onkeyup="loadHistory()" />
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle border">
                <thead class="bg-light">
                    <tr class="small text-muted text-uppercase">
                        <th width="40" class="text-center">EXP</th>
                        <th>Voucher No</th>
                        <th>Departments</th>
                        <th class="text-center">Total Employees</th>
                        <th class="text-end">Total Amount</th>
                        <th class="text-end pe-4">Month / Year</th>
                    </tr>
                </thead>
                <tbody id="tblBody">
                    <tr><td colspan="6" class="text-center py-5">Loading history...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/employee_kharchi_list.js" asp-append-version="true"></script>
}
