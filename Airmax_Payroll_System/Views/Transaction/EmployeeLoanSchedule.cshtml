@* Path: Views/Transaction/EmployeeLoanSchedule.cshtml *@
@{
    ViewBag.Title = "Employee Loan Schedule";
}

<div class="container-fluid py-4" style="background: #f8fafc; min-height: 100vh;">
    <!-- Main Search Card -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
        <div class="card-body p-4">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="small fw-bold text-muted mb-1 d-block ms-1">Search Name/Code/Loan#</label>
                    <input type="text" id="txtSearch" class="form-control border-0 bg-light py-2" placeholder="Type to filter..." onkeyup="loadEmployeesWithLoans()">
                </div>
                <div class="col-md-3">
                    <label class="small fw-bold text-muted mb-1 d-block ms-1">Division</label>
                    <select id="IDDivision" class="form-select border-0 bg-light py-2" onchange="loadEmployeesWithLoans()"></select>
                </div>
                
                <div class="col-md-4">
                    <label class="small fw-bold text-muted mb-1 d-block ms-1">Select Employee Result</label>
                    <select id="IDEmployeeLoan" class="form-select border-0 bg-light py-2"></select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-dark w-100 fw-bold py-2 shadow-sm" onclick="showSchedule()">
                        <i class="fa fa-eye me-1"></i> Show
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats and Grid (Hidden until 'Show' is clicked) -->
    <div id="schedArea" class="d-none">
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="bg-white p-3 rounded shadow-sm border-start border-primary border-4">
                    <small class="text-muted fw-bold d-block mb-1" style="font-size:10px">LOAN NO</small>
                    <h5 class="fw-bold mb-0" id="lblLoanNo"></h5>
                </div>
            </div>
            <div class="col-md-3">
                <div class="bg-white p-3 rounded shadow-sm border-start border-success border-4">
                    <small class="text-muted fw-bold d-block mb-1" style="font-size:10px">PRINCIPAL</small>
                    <h5 class="fw-bold mb-0 text-success" id="lblPrincipal"></h5>
                </div>
            </div>
            <div class="col-md-3">
                <div class="bg-white p-3 rounded shadow-sm border-start border-warning border-4">
                    <small class="text-muted fw-bold d-block mb-1" style="font-size:10px">REPAYMENT</small>
                    <h5 class="fw-bold mb-0" id="lblPaid"></h5>
                </div>
            </div>
            <div class="col-md-3">
                <div class="bg-white p-3 rounded shadow-sm border-start border-danger border-4">
                    <small class="text-muted fw-bold d-block mb-1" style="font-size:10px">OUTSTANDING</small>
                    <h5 class="fw-bold mb-0 text-danger" id="lblOutstanding"></h5>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 15px;">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light small fw-bold text-uppercase">
                    <tr>
                        <th class="text-center py-3">#</th>
                        <th>Month</th>
                        <th>EMI Amount</th>
                        <th>Status</th>
                        <th>Reference</th>
                    </tr>
                </thead>
                <tbody id="schedTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/employee_loan_schedule.js" asp-append-version="true"></script>
}
