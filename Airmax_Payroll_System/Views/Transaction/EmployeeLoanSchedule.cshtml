@* Path: Views/Transaction/EmployeeLoanSchedule.cshtml *@
@{
    ViewBag.Title = "Employee Loan Schedule";
}

<div class="container-fluid py-4" style="background: #f1f5f9; min-height: 100vh;">

    <div class="d-flex justify-content-between mb-3">
        <h4 class="fw-bold">Loan Analytics Dashboard</h4>
        <a href="/Transaction/EmployeeLoanList" class="btn btn-sm btn-outline-secondary">Back to List</a>
    </div>
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
        <div class="card-header bg-white border-0 py-3">
            <h5 class="fw-bold mb-0 text-dark">Loan Repayment Schedule</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="x-small fw-bold text-muted mb-1 text-uppercase">Division</label>
                    <select id="schedDiv" class="form-select border-0 bg-light" onchange="onSchedDivChange()"></select>
                </div>
                <div class="col-md-2">
                    <label class="x-small fw-bold text-muted mb-1 text-uppercase">Department</label>
                    <select id="schedDept" class="form-select border-0 bg-light" onchange="onSchedDeptChange()">
                        <option value="">-- Select --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="x-small fw-bold text-muted mb-1 text-uppercase">Employee</label>
                    <select id="schedEmp" class="form-select border-0 bg-light" onchange="onSchedEmpChange()">
                        <option value="">-- Select --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="x-small fw-bold text-muted mb-1 text-uppercase">Loan No</label>
                    <select id="schedLoan" class="form-select border-0 bg-light">
                        <option value="">-- Select --</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-dark w-100 fw-bold py-2 shadow-sm" onclick="showSchedule()">
                        <i class="fa fa-calendar-check me-2"></i>Show Schedule
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Box & Table -->
    <div id="schedInfoBox" class="d-none animate__animated animate__fadeIn">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h6 class="text-muted x-small fw-bold mb-1">SELECTED LOAN</h6>
                <h4 class="fw-bold mb-0" id="lblLoanNo"></h4>
            </div>
            <div class="d-flex gap-2">
                <div class="bg-white p-2 px-3 rounded shadow-sm border-start border-primary border-4">
                    <small class="text-muted x-small d-block fw-bold">Principal</small>
                    <span class="fw-bold" id="lblPrincipal"></span>
                </div>
                <div class="bg-white p-2 px-3 rounded shadow-sm border-start border-success border-4">
                    <small class="text-muted x-small d-block fw-bold">Recovery Status</small>
                    <span class="fw-bold text-success" id="lblPaid"></span>
                </div>
                <div class="bg-white p-2 px-3 rounded shadow-sm border-start border-warning border-4">
                    <small class="text-muted x-small d-block fw-bold">Outstanding</small>
                    <span class="fw-bold text-warning" id="lblOutstanding"></span>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
            <table class="table table-hover mb-0">
                <thead class="bg-white text-muted x-small text-uppercase">
                    <tr>
                        <th class="text-center" style="width: 50px;">#</th>
                        <th>Inst. Date</th>
                        <th>EMI Amount</th>
                        <th>Status</th>
                        <th>Deduction Reference</th>
                    </tr>
                </thead>
                <tbody id="schedTableBody" class="bg-white align-middle">
                    <!-- Dynamic Rows -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .x-small {
        font-size: 11px;
    }

    .bg-success-light {
        background: #dcfce7;
    }
</style>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/employee_loan_schedule.js" asp-append-version="true"></script>
}
