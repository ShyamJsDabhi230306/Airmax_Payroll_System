@{
    ViewBag.Title = "Employee Loan";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Employee Loan List</h4>
                <a onclick="addNewEntry()" class="btn btn-primary btn-sm">Add New Loan</a>
            </div>

            <div class="table-responsive">
                <table id="loanList" class="table table-striped table-hover w-100">
                    <thead class="table-primary">
                        <tr>
                            <th class="text-center" style="width:70px">Sr No</th>
                            <th class="text-center">Loan No</th>
                            <th>Employee Name</th>
                            <th class="text-center">Amount</th>
                            <th class="text-center">Installments</th>
                            <th class="text-center">Status</th>
                            <th class="text-center" style="width:80px">Action</th>
                        </tr>
                    </thead>
                    <tbody id="tblBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ================= MODAL ================= -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Employee Loan Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="entryForm">
                    <input type="hidden" id="IDEmployeeLoan" value="0" />

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Sr. No (Loan No)</label>
                            <input type="text" id="LoanNo" class="form-control" readonly />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Date</label>
                            <input type="date" id="Date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Department</label>
                            <select id="IDDepartment" class="form-control"></select>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Select Employee</label>
                            <select id="IDEmployee" class="form-control">
                                <option value="">Select Employee</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Loan Amount</label>
                            <input type="number" id="LoanAmount" class="form-control text-end" value="0.00" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Total Installments</label>
                            <input type="number" id="TotalInstallments" class="form-control" value="0" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Starting Date</label>
                            <div class="input-group">
                                <input type="date" id="InstallmentStartingDate" class="form-control" />
                                <button type="button" onclick="generateInstallments()" class="btn btn-info">Add Months</button>
                            </div>
                        </div>
                    </div>

                    <hr />
                    <h6 class="mb-3">Monthly Installment Details</h6>
                    <!-- Inside your Modal Body -->
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm">
                            <!-- table-sm makes it more compact -->
                            <thead class="table-secondary text-center">
                                <tr>
                                    <th style="width:70px">Sr No</th>
                                    <th style="width:100px">Month</th>
                                    <th style="width:100px">Year</th>
                                    <th>Installment Amount</th>
                                    <th style="width:60px">#</th>
                                </tr>
                            </thead>
                            <tbody id="tblLoanBody" class="text-center"></tbody> <!-- Text center for Month/Year cells -->
                            <tfoot>
                                <tr class="table-light">
                                    <th colspan="3" class="text-end fw-bold">Total Planned Amount:</th>
                                    <th id="lblTotalAmount" class="text-end fw-bold px-3 text-primary">0.00</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="btnSave">Save / Update</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/employee_loan.js" asp-append-version="true"></script>
}
