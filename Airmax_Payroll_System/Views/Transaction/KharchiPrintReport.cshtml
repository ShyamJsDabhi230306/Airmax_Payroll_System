@model Airmax_Payroll_System.Models.AllDTOS.TransactionEmployeeKharchiSaveDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Print Kharchi - @Model.KharchiNo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            padding: 30px;
        }

        .dept-group {
            margin-top: 25px;
            border: 1px solid #ddd;
            border-radius: 8px;
            overflow: hidden;
        }

        .dept-header {
            background: #2c3e50;
            color: white;
            padding: 10px 15px;
            font-weight: bold;
        }
        @@media print {
            .no-print

        {
            display: none;
        }

        }
    </style>
</head>
<body onload="window.print()">
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
        <h2 class="fw-bold text-primary">KHARCHI REPORT</h2>
        <div class="text-end">
            <h5 class="mb-0">Voucher: <b>@Model.KharchiNo</b></h5>
            <small>Month: @Model.KharchiDate?.ToString("MMMM, yyyy")</small>
        </div>
    </div>

    @foreach (var deptGroup in Model.Details.GroupBy(x => x.DepartmentName))
    {
        <div class="dept-group">
            <div class="dept-header">@deptGroup.Key</div>
            <table class="table table-sm table-striped mb-0">
                <thead>
                    <tr><th>#</th><th>Employee</th><th>Code</th><th class="text-end">Amount</th></tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var emp in deptGroup)
                    {
                        <tr>
                            <td>@(i++)</td>
                            <td>@emp.EmployeeName</td>
                            <td>@emp.EmployeeCode</td>
                            <td class="text-end">@emp.Amount?.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="text-end mt-4 h4 fw-bold">Grand Total: ₹ @Model.Details.Sum(x => x.Amount)?.ToString("N2")</div>
</body>
</html>


@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/kharchi_print_report.js" asp-append-version="true"></script>


}
