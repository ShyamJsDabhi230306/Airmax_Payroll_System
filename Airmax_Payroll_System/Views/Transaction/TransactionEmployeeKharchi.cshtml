@{
    ViewBag.Title = "Employee Kharchi";
}

<div class="row">
    <div class="col-12">
        <div class="card">

            <div class="card-header">
                <h4 class="card-title">Employee Kharchi</h4>

                @* <a data-bs-toggle="modal"
                   data-bs-target="#addModal"
                   class="btn btn-primary btn-sm">
                    Add Kharchi
                </a> *@
                <a onclick="addNewEntry()" class="btn btn-primary btn-sm">
                    Add Kharchi
                </a>
            </div>

            <div class="table-responsive">

                <table id="kharchiList"
                       class="table table-striped table-hover w-100">

                    <thead class="table-primary">
                        <tr>
                            <th>Sr No</th>
                            <th>Employee Name</th>
                            <th>Department</th>
                            <th>Kharchi Month</th>
                            <th>Amount</th>
                            <th style="width:2%">Action</th>
                        </tr>
                    </thead>

                    <tbody id="tblBody"></tbody>

                </table>

            </div>

        </div>
    </div>
</div>



<!-- MODAL -->

<div class="modal fade" id="addModal" tabindex="-1">

    <div class="modal-dialog modal-xl modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Employee Kharchi</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>


            <div class="modal-body">

                <form id="entryForm">

                    <input type="hidden" id="IDEmployeeKharchi" value="0" />

                    <div class="row g-3">

                        <!-- Kharchi No -->
                        <div class="col-md-4">
                            <label class="form-label">Kharchi No</label>

                            <input type="text"
                                   id="KharchiNo"
                                   class="form-control"
                                   readonly />
                        </div>

                        <!-- Kharchi Date -->
                        <div class="col-md-4">
                            <label class="form-label">Kharchi Month</label>

                            <input type="month"
                                   id="KharchiDate"
                                   class="form-control" />
                        </div>

                        <!-- Entry Date -->
                        <div class="col-md-4">
                            <label class="form-label"> Date</label>

                            <input type="date"
                                   id="Date"
                                   class="form-control" readonly />
                        </div>

                        <!-- Department -->
                        <div class="col-md-12">
                            <label class="form-label">Department</label>

                            <select id="IDDepartment" class="form-control">
                                <option value="">Select Department</option>
                            </select>
                        </div>

                    </div>

                    <hr />

                    <!-- 🔥 EMPLOYEE GRID -->
                    <div class="table-responsive mt-3">

                        <!-- 🔥 Employee Select + Add -->
                        <div class="d-flex gap-2 mb-2">
                            <select id="ddlEmployee" class="form-control">
                                <option value="">Select Employee</option>
                            </select>

                            <button type="button" onclick="addEmployeeRow()" class="btn btn-primary">
                                Add
                            </button>
                        </div>

                        <!-- 🔥 TABLE (YOU MISSED THIS) -->
                        <table class="table table-bordered">

                            <thead class="table-secondary">
                                <tr>
                                    <th style="width:50px">#</th>
                                    <th>Employee Code</th>
                                    <th>Employee Name</th>
                                    <th style="width:150px">Amount</th>
                                    <th style="width:120px">Allow</th>
                                    <th style="width:80px">Action</th>
                                </tr>
                            </thead>

                            <tbody id="tblEmployeeBody"></tbody>

                        </table>

                    </div>

                </form>

            </div>


            <div class="modal-footer">

                <button class="btn btn-light"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button class="btn btn-primary"
                        id="btnSave">
                    Save
                </button>

            </div>

        </div>
    </div>
</div>


@section Scripts {
    <script src="~/AirmaxPayRollJS/Master/kharchi.js" asp-append-version="true"></script>
}