@* Path: Airmax_Payroll_System/Views/Transaction/EmployeeLoanList.cshtml *@
@{
    ViewBag.Title = "Employee Loan List";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <!-- Path: Views/Transaction/EmployeeLoanList.cshtml -->

            <div class="card border-0 shadow-sm mb-3" style="border-radius: 15px;">
                <div class="card-body p-3">
                    <div class="row align-items-center">
                        <!-- Left Side: Title -->
                        <div class="col-md-4">
                            <h4 class="fw-bold mb-0 text-dark">
                                <i class="fa fa-money-bill-wave text-primary me-2"></i>Employee Loan List
                            </h4>
                        </div>

                        <!-- Right Side: Action Buttons -->
                        <div class="col-md-8 text-end">
                            <div class="btn-group shadow-sm" style="border-radius: 10px; overflow: hidden;">

                                <!-- Add New Button -->
                                <a href="/Transaction/EmployeeLoanEntry" class="btn btn-primary px-3 fw-bold">
                                    <i class="fa fa-plus-circle me-1"></i> Add New Loan
                                </a>

                                <!-- Dashboard Button -->
                                <a href="/Transaction/EmployeeLoanDashboard" class="btn btn-dark px-3 fw-bold">
                                    <i class="fa fa-chart-pie me-1"></i> Dashboard
                                </a>

                                <!-- EMI Schedule Button -->
                                <a href="/Transaction/EmployeeLoanSchedule" class="btn btn-info text-white px-3 fw-bold">
                                    <i class="fa fa-calendar-alt me-1"></i> EMI Schedule
                                </a>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table id="loanList" class="table table-striped table-hover w-100">
                        <thead class="table-primary">
                            <tr>
                                <th class="text-center" style="width:70px">Sr No</th>
                                <th class="text-center">Loan No</th>
                                <th>Employee Name</th>
                                <th class="text-center">Amount</th>
                                <th class="text-center">Installments</th>
                                <th class="text-center">Status</th>
                                <th class="text-center" style="width:80px">Action</th>
                            </tr>
                        </thead>
                        <tbody id="tblBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/employee_loan_list.js" asp-append-version="true"></script>
}
