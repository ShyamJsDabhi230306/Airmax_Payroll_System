@* Path: Airmax_Payroll_System/Views/Transaction/EmployeeLoanList.cshtml *@
@{
    ViewBag.Title = "Employee Loan List";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title">Employee Loan List</h4> 
                <a href="/Transaction/EmployeeLoanEntry" class="btn btn-primary btn-sm btn-add">Add New Loan</a>
                <a href="/Transaction/EmployeeLoanDashboard" class="btn btn-dark btn-sm me-2">
                    <i class="fa fa-dashboard me-1"></i> Dashboard
                </a>
                <a href="/Transaction/EmployeeLoanSchedule" class="btn btn-primary">View EMI Schedule</a>

            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="loanList" class="table table-striped table-hover w-100">
                        <thead class="table-primary">
                            <tr>
                                <th class="text-center" style="width:70px">Sr No</th>
                                <th class="text-center">Loan No</th>
                                <th>Employee Name</th>
                                <th class="text-center">Amount</th>
                                <th class="text-center">Installments</th>
                                <th class="text-center">Status</th>
                                <th class="text-center" style="width:80px">Action</th>
                            </tr>
                        </thead>
                        <tbody id="tblBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AirmaxPayRollJS/Transaction/employee_loan_list.js" asp-append-version="true"></script>
}
